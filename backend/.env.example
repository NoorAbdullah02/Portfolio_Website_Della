# Server
PORT=3001
CORS_ORIGIN=http://localhost:3000

# PostgreSQL — either set DATABASE_URL, or the discrete PG* vars below
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/della_portfolio
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=della_portfolio
# PGSSL=false

# AI integration (Mistral API — https://console.mistral.ai/)
MISTRAL_API_KEY=your-mistral-key-here
MISTRAL_MODEL=mistral-large-latest

# Optional: protects GET /api/contact (view submitted messages)
ADMIN_KEY=change-me
